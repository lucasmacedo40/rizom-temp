# ─── Servidor ───────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Banco de dados ──────────────────────────────────────
DATABASE_URL=postgresql://rizomtemp:SENHA_FORTE@localhost:5432/rizomtemp

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=troque_por_string_aleatoria_longa_de_64_chars
JWT_EXPIRES_IN=7d

# ─── MQTT (Mosquitto local no VPS) ───────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=rizomtemp_server
MQTT_PASSWORD=senha_interna_servidor

# ─── Alertas via n8n ─────────────────────────────────────
N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/rizom-temp-alerta

# ─── Limites de temperatura ANVISA (defaults) ────────────
# Podem ser sobrescritos por cliente/equipamento no banco
TEMP_CAMARA_FRIA_MIN=-18
TEMP_CAMARA_FRIA_MAX=-15
TEMP_FREEZER_MIN=-18
TEMP_FREEZER_MAX=-10
TEMP_REFRIGERADOR_MIN=0
TEMP_REFRIGERADOR_MAX=5
TEMP_EXPOSITOR_MIN=0
TEMP_EXPOSITOR_MAX=10

# ─── Relatórios ──────────────────────────────────────────
REPORT_TIMEZONE=America/Recife
